# ============================================
# Fut5-Germinare - Configuração de Ambiente
# ============================================

# API Configuration
# ==================
# URL base da API
# Desenvolvimento: http://localhost:3000
# Produção: https://api.fut5germinare.com
API_BASE_URL=https://api.fut5germinare.com

# Timeout para requisições em ms
API_TIMEOUT=5000

# Número de tentativas de retry
API_RETRY_ATTEMPTS=3

# Delay entre tentativas em ms
API_RETRY_DELAY=1000

# Authentication
# ===============
# Ativar autenticação
AUTH_ENABLED=true

# JWT Secret (apenas servidor)
# JWT_SECRET=your_secret_key_here

# Token expiry em minutos
# TOKEN_EXPIRY=30

# Environment
# ============
# Ambiente: development, staging, production
NODE_ENV=production

# Debug mode
DEBUG=false

# Logging
# ========
# Nível de log: error, warn, info, debug
LOG_LEVEL=info

# Feature Flags
# ==============
# Ativar beta features
BETA_FEATURES=false

# Ativar analytics
ANALYTICS_ENABLED=true

# Ativar offline mode (futuro)
OFFLINE_MODE=false
